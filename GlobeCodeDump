function mouseMoved() {
// Interactive rotation based on mouse position
let targetRotX = map(mouseY, 0, height, -0.3, 0.3);
let targetRotY = map(mouseX, 0, width, -0.3, 0.3);

rotationX = lerp(rotationX, targetRotX, 0.05);
rotationY += (targetRotY - rotationY) * 0.02;
}