function setup() {
createCanvas(800, 600, WEBGL);

// Create starfield
for (let i = 0; i < 200; i++) {
stars.push({
x: random(-width * 2, width * 2),
y: random(-height * 2, height * 2),
z: random(-1000, 200),
size: random(1, 3)
});
}
}

function draw() {
background(5, 10, 25);

